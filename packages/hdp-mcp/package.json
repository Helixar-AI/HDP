{
  "name": "@helixar_ai/hdp-mcp",
  "version": "0.1.3",
  "description": "HDP middleware for MCP (Model Context Protocol) servers",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@helixar_ai/hdp": "file:../.."
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "tsup": "^8.5.1",
    "vitest": "^4.1.1",
    "@types/node": "^25.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Helixar-AI/HDP.git",
    "directory": "packages/hdp-mcp"
  },
  "license": "Apache-2.0"
}
